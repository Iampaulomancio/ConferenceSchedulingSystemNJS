<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h1 class="fw-bold mb-1">My Bookings</h1>
    <p class="text-secondary mb-0">Only your own reservations can be cancelled from this page.</p>
  </div>
  <a href="/bookings/new" class="btn btn-primary">New Reservation</a>
</div>

<div class="card shadow-sm border-0 rounded-4">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Room</th>
          <th>Schedule</th>
          <th>Purpose</th>
          <th>Meeting Type</th>
          <th>Status</th>
          <th class="text-end">Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (!bookings.length) { %>
          <tr><td colspan="6" class="text-center py-4 text-secondary">No bookings yet.</td></tr>
        <% } %>
        <% bookings.forEach(booking => { %>
          <tr>
            <td>
              <div class="fw-semibold"><%= booking.room_name %></div>
              <small class="text-secondary"><%= booking.location || '' %></small>
            </td>
            <td>
              <div><%= dayjs(booking.start_datetime).format('MMM D, YYYY') %></div>
              <small class="text-secondary"><%= dayjs(booking.start_datetime).format('h:mm A') %> - <%= dayjs(booking.end_datetime).format('h:mm A') %></small>
            </td>
            <td><%= booking.purpose || '-' %></td>
            <td>
              <span class="badge <%= booking.meeting_type === 'online' ? 'text-bg-info' : 'text-bg-secondary' %>"><%= booking.meeting_type %></span>
              <% if (booking.zoom_link_required) { %><div><small class="text-warning">Needs Zoom link</small></div><% } %>
            </td>
            <td><span class="badge <%= booking.status === 'active' ? 'text-bg-success' : 'text-bg-danger' %>"><%= booking.status %></span></td>
            <td class="text-end">
              <% if (booking.status === 'active') { %>
                <form action="/bookings/<%= booking.id %>/cancel" method="POST" onsubmit="return confirm('Cancel this booking?')">
                  <button class="btn btn-outline-danger btn-sm">Cancel</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
