<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h1 class="fw-bold mb-1">Reservation Calendar</h1>
    <p class="text-secondary mb-0">View occupied and vacant schedules by conference room.</p>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <select id="roomFilter" class="form-select">
      <option value="">All Rooms</option>
      <% rooms.forEach(room => { %>
        <option value="<%= room.id %>"><%= room.name %></option>
      <% }) %>
    </select>
    <a href="/bookings/new" class="btn btn-primary">Reserve</a>
  </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
  <div class="card-body">
    <div id="calendar"></div>
  </div>
</div>

<script>
  window.calendarConfig = {
    eventsUrl: '/api/bookings'
  };
</script>
