<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h1 class="fw-bold mb-1">Dashboard</h1>
    <p class="text-secondary mb-0">Manage conference room schedules in one place.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/bookings/new" class="btn btn-primary">New Reservation</a>
    <a href="/calendar" class="btn btn-outline-primary">Open Calendar</a>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-secondary">Upcoming Bookings</div><div class="display-6 fw-bold"><%= stats.upcomingBookings || 0 %></div></div></div></div>
  <div class="col-md-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-secondary">Online Meeting Requests</div><div class="display-6 fw-bold"><%= stats.onlineMeetingNeeds || 0 %></div></div></div></div>
  <div class="col-md-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-secondary">Active Rooms</div><div class="display-6 fw-bold"><%= stats.activeRooms || 0 %></div></div></div></div>
</div>

<div class="card shadow-sm border-0 rounded-4">
  <div class="card-body">
    <h5 class="fw-bold mb-3">Available Conference Rooms</h5>
    <div class="row g-3">
      <% rooms.forEach(room => { %>
        <div class="col-md-6 col-xl-4">
          <div class="border rounded-4 p-3 h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h6 class="fw-bold mb-0"><%= room.name %></h6>
              <span class="badge <%= room.is_active ? 'text-bg-success' : 'text-bg-secondary' %>"><%= room.is_active ? 'Active' : 'Inactive' %></span>
            </div>
            <div class="text-secondary small mb-2"><%= room.location || 'No location' %></div>
            <div class="small">Capacity: <strong><%= room.capacity %></strong></div>
            <p class="small text-secondary mt-2 mb-0"><%= room.description || 'No description yet.' %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
